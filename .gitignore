# Python virtual environment
.venv/
__pycache__/
*.pyc

# Credential files — never commit these
.env
tests/integration/.env  # integration test secrets (user_id, user_secret, api keys)

# Editor config with credentials
.cursor/mcp.json  # Cursor MCP config may contain API keys

# Build artifacts
dist/
*.egg-info/

# Test coverage output — generated by pytest-cov, not source files
.coverage
htmlcov/
